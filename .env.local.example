# ------------------------------------------------------------------------------
# Servicimmo v2 — Variables d'environnement
# Copier ce fichier vers `.env.local` et remplir les valeurs.
# Ne JAMAIS committer `.env.local` (cf. .gitignore).
# ------------------------------------------------------------------------------

# --- Supabase ---------------------------------------------------------------
# URL publique du projet Supabase (format : https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clé anon (publique, côté client — limitée par les policies RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service_role (SECRÈTE — côté serveur uniquement, bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=

# --- Email transactionnel (Resend) ------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=

# Adresse d'expédition des emails (domaine validé dans Resend)
EMAIL_FROM=devis@servicimmo.fr

# Adresse interne qui reçoit les notifications "nouvelle demande"
EMAIL_INTERNAL_NOTIFICATION=contact@servicimmo.fr

# --- Analytics (RGPD-friendly) ----------------------------------------------
# Domaine configuré dans Plausible (ex: servicimmo.fr)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=servicimmo.fr

# --- App --------------------------------------------------------------------
# URL publique utilisée pour metadataBase, liens emails, redirections OAuth
NEXT_PUBLIC_APP_URL=http://localhost:3000
